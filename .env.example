BIND_ADDRESS=127.0.0.1:3000
BLOB_ROOT=.pyregistry/blobs
DATABASE_STORE=in-memory
ARTIFACT_STORAGE_BACKEND=opendal
OPENDAL_SCHEME=fs
OPENDAL_ROOT=.pyregistry/blobs
# For S3-compatible storage, set OPENDAL_SCHEME=s3 plus:
# OPENDAL_BUCKET=pyregistry
# OPENDAL_ENDPOINT=http://127.0.0.1:9000
# OPENDAL_REGION=us-east-1
# OPENDAL_ACCESS_KEY_ID=pyregistry
# OPENDAL_SECRET_ACCESS_KEY=pyregistry123
# OPENDAL_ROOT=/artifacts
# OPENDAL_DISABLE_CONFIG_LOAD=true
# OPENDAL_DISABLE_EC2_METADATA=true
# OPENDAL_ENABLE_VIRTUAL_HOST_STYLE=false
PYPI_BASE_URL=https://pypi.org
YARA_RULES_PATH=supplied/signature-base/yara
PYSENTRY_IGNORE_VULNERABILITY_IDS=
YARA_IGNORE_RULE_IDS=
FOXGUARD_IGNORE_RULE_IDS=
DATABASE_URL=postgres://pyregistry:pyregistry@127.0.0.1:5432/pyregistry
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_MIN_CONNECTIONS=2
POSTGRES_ACQUIRE_TIMEOUT_SECONDS=10
SQL_SERVER_URL=sqlserver://sa:Pyregistry123!@127.0.0.1:1433/pyregistry?trust_server_certificate=true
SQL_SERVER_MAX_CONNECTIONS=20
SQL_SERVER_MIN_CONNECTIONS=2
SQL_SERVER_ACQUIRE_TIMEOUT_SECONDS=10
LOG_FILTER=info
LOG_MODULE_PATH=true
LOG_TARGET=false
LOG_TIMESTAMP=seconds
SUPERADMIN_EMAIL=admin@pyregistry.local
SUPERADMIN_PASSWORD=change-me-now
COOKIE_SECRET=replace-me-with-a-long-random-string
OIDC_ISSUERS=github|https://issuer.pyregistry.local|http://127.0.0.1:8081/jwks.json|pyregistry
NETWORK_SOURCE_WEB_UI_ALLOWED_CIDRS=
NETWORK_SOURCE_API_ALLOWED_CIDRS=
NETWORK_SOURCE_TRUST_PROXY_HEADERS=false
